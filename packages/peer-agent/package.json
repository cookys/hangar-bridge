{
  "name": "@hangar-bridge/peer-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "hangar-bridge-peer-agent": "./dist/index.js",
    "hangar-bridge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('coverage',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@hangar-bridge/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@nats-io/jetstream": "^3.4.0",
    "@nats-io/kv": "^3.4.0",
    "@nats-io/transport-node": "^3.4.0",
    "ulid": "^2.3.0",
    "undici": "^6.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.2"
  }
}
