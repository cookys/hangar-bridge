{
  "name": "hangar-bridge",
  "private": true,
  "version": "0.1.0",
  "description": "Claude Code Channels MCP server for cross-host fleet dispatch — fork of pouriamrt/claude-mesh with single-tenant per-host shared-secret auth and task_dispatch/task_result envelopes",
  "license": "MIT",
  "author": "cookys (fork maintainer)",
  "contributors": [
    {
      "name": "Pouria Mortezaagha",
      "url": "https://github.com/pouriamrt",
      "comment": "original author of pouriamrt/claude-mesh (MIT), the upstream from which hangar-bridge is forked"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cookys/hangar-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/cookys/hangar-bridge/issues"
  },
  "homepage": "https://github.com/cookys/hangar-bridge#readme",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "mcp",
    "model-context-protocol",
    "channels",
    "fleet-dispatch",
    "cross-host"
  ],
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:ci": "pnpm -r test:ci",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "fast-check": "^3.22.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  }
}
